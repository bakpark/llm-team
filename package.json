{
  "name": "llm-team",
  "version": "0.1.0",
  "private": true,
  "description": "LLM Team — agent runner port + provider adapters (TypeScript runtime)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "healthcheck": "tsx src/cli/healthcheck.ts",
    "healthcheck:stage1": "tsx src/cli/healthcheck.ts --stage 1",
    "healthcheck:stage2": "tsx src/cli/healthcheck.ts --stage 2",
    "healthcheck:stage3": "tsx src/cli/healthcheck.ts --stage 3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  }
}
