#!/usr/bin/env bash
# llm-team command line entrypoint.

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "${SOURCE}" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "${SOURCE}")" && pwd)"
  LINK_TARGET="$(readlink "${SOURCE}")"
  case "${LINK_TARGET}" in
    /*) SOURCE="${LINK_TARGET}" ;;
    *) SOURCE="${SOURCE_DIR}/${LINK_TARGET}" ;;
  esac
done
SCRIPT_DIR="$(cd -P "$(dirname "${SOURCE}")" && pwd)"
LLM_TEAM_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export LLM_TEAM_ROOT

usage() {
  cat <<EOF
Usage: llm-team <command> [args]

Commands:
  doctor [target]                  Check local prerequisites and target config
  target <list|show|add|enable|disable>
  labels bootstrap <target> [--dry-run]
  run <role> <target> [--dry-run]
  run-once <target> [--roles list] [--dry-run]
  daemon <start|stop|status|logs>
  status [target]
  dashboard [--out path] [--target name]... [--lines N] [--no-github]
  pause [--all]
  resume [--all]

Use "llm-team <command> --help" for command-specific help.
EOF
}

cmd="${1:-help}"
case "${cmd}" in
  -h|--help|help)
    usage
    ;;
  doctor)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/doctor.sh" "$@"
    ;;
  target)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/target.sh" "$@"
    ;;
  labels)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/labels.sh" "$@"
    ;;
  run)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/run.sh" run "$@"
    ;;
  run-once)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/run.sh" run-once "$@"
    ;;
  daemon)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/daemon.sh" "$@"
    ;;
  status)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/status.sh" "$@"
    ;;
  dashboard)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/dashboard.sh" "$@"
    ;;
  pause|resume)
    shift
    exec "${LLM_TEAM_ROOT}/scripts/cli/control.sh" "${cmd}" "$@"
    ;;
  version)
    printf 'llm-team dev\n'
    ;;
  *)
    printf 'ERROR: unknown command: %s\n\n' "${cmd}" >&2
    usage >&2
    exit 64
    ;;
esac
