# 실제 키는 본 파일을 `.env`로 복사한 뒤 채워 넣을 것.
# `.env`는 .gitignore에 의해 추적되지 않는다.

# GitHub 토큰 (gh CLI가 권한을 가진 PAT)
# 필요한 권한: repo, workflow (Milestone/Issue/PR/Label CRUD)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Notifier webhooks (targets/<name>.yaml의 notifier.webhook_or_id가 참조하는 키)
DISCORD_WEBHOOK_MYAPP=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_MYAPP=https://hooks.slack.com/services/...
